# Vercel AI Gateway
AI_GATEWAY_API_KEY=your_vercel_gateway_key

# Nia API
NIA_API_KEY=your_nia_key
NIA_CODEBASE_SOURCE=your_pickup_lines_source_id

# Telegram HTTP Bridge
TELEGRAM_API_URL=http://localhost:8765

# TTS / Voice Replies
TTS_PROVIDER=elevenlabs
TTS_API_KEY=your_elevenlabs_api_key
TTS_VOICE_ID=your_elevenlabs_voice_id
TTS_MODEL=eleven_multilingual_v2
TTS_OUTPUT_FORMAT=ogg_opus
