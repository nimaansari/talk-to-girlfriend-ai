# Telegram API Credentials (Required - get from https://my.telegram.org/apps)
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Session Management (Choose ONE)
# Option 1: File-based session (a .session file will be created)
TELEGRAM_SESSION_NAME=telegram_session

# Option 2: String-based session (if you generate one, e.g., using Telethon's string session generator)
TELEGRAM_SESSION_STRING=

# Telegram HTTP Bridge
TELEGRAM_API_URL=http://localhost:8765

# AI Gateway API Credentials
AI_GATEWAY_API_KEY=your_vercel_gateway_key

# NIA API Credentials
NIA_API_KEY=your_nia_key

# NIA Codebase Source
NIA_CODEBASE_SOURCE=arlanrakh/curation-of-pickup-lines

# TTS / Voice Replies
# Primary supported provider today: elevenlabs
# Future-compatible values: openai, custom providers added via tts_service.py
TTS_PROVIDER=elevenlabs
TTS_API_KEY=your_elevenlabs_api_key
TTS_VOICE_ID=your_elevenlabs_voice_id
TTS_MODEL=eleven_multilingual_v2
TTS_OUTPUT_FORMAT=ogg_opus
# Optional tuning
TTS_TIMEOUT_SECONDS=45
TTS_RETRIES=2
# TTS_TEMP_DIR=/tmp
